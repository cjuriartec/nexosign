{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NexoSign",
  "version": "1.0.1",
  "identifier": "com.nexosign.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "NexoSign",
        "width": 800,
        "height": 600,
        "minWidth": 580,
        "minHeight": 580
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "shortDescription": "Firma PDF PAdES con certificado en hardware (PKCS#11)",
    "copyright": "Copyright © NexoSign contributors",
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
