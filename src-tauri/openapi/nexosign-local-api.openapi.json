{
  "openapi": "3.0.3",
  "info": {
    "title": "NexoSign API local",
    "description": "API HTTP en loopback (`127.0.0.1:14500`) cuando NexoSign está en ejecución.\n\n**CORS / origen:** las rutas batch exigen un origen de confianza. `GET /api/v1/origin/check` usa cabecera **`Origin`** (navegador) o **`X-Client-Origin`** (respaldo en loopback). Si `trusted` es false, `POST /api/v1/origin/prompt` abre el diálogo «Confiar» o añade la URL en Ajustes → Sitios permitidos. En **Swagger (`/docs`)** rellena solo una de las dos cabeceras.\n\n**Portal sin backend:** tras `POST …/batch/sign/intent`, sondea `GET /api/v1/batch/sign/intent/{request_id}/status` hasta `completed`; luego `GET …/jobs/{job_id}/signed-files` y cada `GET …/files/{i}`.\n\n**No incluido aquí:** la encolación directa de firma (`POST …/batch/sign`) ni el sondeo fino de progreso por `job_id` de la app de escritorio.\n\n**Scalar / otros:** importa `http://127.0.0.1:14500/openapi.json` con la app abierta.",
    "version": "0.1.0"
  },
  "servers": [
    {
      "url": "http://127.0.0.1:14500",
      "description": "API local (solo con la app en marcha)"
    }
  ],
  "tags": [
    { "name": "health", "description": "Estado del servicio" },
    { "name": "origins", "description": "Comprobar y autorizar orígenes (CORS / sitios permitidos)" },
    { "name": "utils", "description": "Utilidades (ping, enfocar ventana)" },
    { "name": "batch", "description": "Firma por lotes (intent, estado, descargas); política de origen en el servidor" }
  ],
  "components": {
    "parameters": {
      "OriginHeader": {
        "name": "Origin",
        "in": "header",
        "required": true,
        "description": "URL de origen del cliente (`http://…`, `https://…`, u otro esquema bien formado). El navegador la envía en integraciones cross-origin; en Swagger puedes fijarla manualmente para probar.",
        "schema": { "type": "string" },
        "example": "http://localhost:1420"
      },
      "OriginHeaderOptional": {
        "name": "Origin",
        "in": "header",
        "required": false,
        "description": "Cabecera estándar del navegador con la URL de origen del cliente (`http://…`, `https://…`). En Swagger, rellénala para probar un portal web.",
        "schema": { "type": "string" },
        "example": "http://localhost:1420"
      },
      "XClientOriginHeader": {
        "name": "X-Client-Origin",
        "in": "header",
        "required": false,
        "description": "**Respaldo** si no envías `Origin`: el cliente declara la misma URL de origen. Solo válida con `Host` en `127.0.0.1:{puerto}` o `localhost:{puerto}`. Usa una u otra cabecera, no hace falta duplicar el valor en ambas.",
        "schema": { "type": "string" },
        "example": "https://portal.ejemplo"
      }
    },
    "schemas": {
      "OriginCheckResponse": {
        "type": "object",
        "required": ["trusted"],
        "properties": {
          "origin": {
            "type": "string",
            "nullable": true,
            "description": "**Campo de respuesta** (no es parámetro de entrada): origen detectado por el servidor, o null si no llegó ninguna cabecera identificable"
          },
          "trusted": {
            "type": "boolean",
            "description": "true si el origen está en sitios permitidos (SQLite + defaults)"
          }
        }
      },
      "OriginPromptResponse": {
        "type": "object",
        "required": ["trusted", "prompted"],
        "properties": {
          "trusted": {
            "type": "boolean",
            "description": "true si el origen quedó autorizado (ya lo estaba o el usuario pulsó «Confiar»)"
          },
          "prompted": {
            "type": "boolean",
            "description": "false si ya estaba autorizado; true si se mostró el diálogo nativo"
          }
        }
      },
      "FocusBody": {
        "type": "object",
        "properties": {
          "intent": {
            "type": "string",
            "description": "Opcional: `request_id` del intent para abrir el asistente de firma"
          }
        }
      },
      "FocusResponse": {
        "type": "object",
        "required": ["ok", "focused"],
        "properties": {
          "ok": { "type": "boolean", "example": true },
          "focused": { "type": "boolean", "example": true }
        }
      },
      "ApiError": {
        "type": "object",
        "properties": {
          "error": { "type": "string" },
          "detail": { "type": "string" },
          "origin": { "type": "string" }
        }
      }
    }
  },
  "paths": {
    "/health": {
      "get": {
        "tags": ["health"],
        "summary": "Salud",
        "operationId": "getHealth",
        "responses": {
          "200": {
            "description": "Servicio activo",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["status", "service", "version"],
                  "properties": {
                    "status": { "type": "string", "example": "ok" },
                    "service": { "type": "string", "example": "nexosign" },
                    "version": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/ping": {
      "post": {
        "tags": ["utils"],
        "summary": "Ping",
        "operationId": "postPing",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["ok"],
                  "properties": {
                    "ok": { "type": "boolean", "example": true }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/origin/check": {
      "get": {
        "tags": ["origins"],
        "summary": "Comprobar si el origen está autorizado",
        "description": "Comprueba si el origen del cliente está en sitios permitidos. En Swagger usa **`Origin`** (portal web) o **`X-Client-Origin`** (cliente local a loopback), no ambos a la vez. Si ninguna llega, `origin: null` y `trusted: false`.",
        "operationId": "getOriginCheck",
        "parameters": [
          { "$ref": "#/components/parameters/OriginHeaderOptional" },
          { "$ref": "#/components/parameters/XClientOriginHeader" }
        ],
        "responses": {
          "200": {
            "description": "Estado de confianza del origen",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/OriginCheckResponse" },
                "examples": {
                  "autorizado": {
                    "value": {
                      "origin": "https://portal.ejemplo",
                      "trusted": true
                    }
                  },
                  "sinOrigin": {
                    "value": { "origin": null, "trusted": false }
                  },
                  "noAutorizado": {
                    "value": {
                      "origin": "https://portal.ejemplo",
                      "trusted": false
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/origin/prompt": {
      "post": {
        "tags": ["origins"],
        "summary": "Diálogo nativo para confiar en el origen",
        "description": "Identifica el cliente con **`Origin`** o, en loopback, **`X-Client-Origin`**. Si no está en la lista, muestra el diálogo «Confiar / Cancelar» y persiste la URL.",
        "operationId": "postOriginPrompt",
        "parameters": [
          { "$ref": "#/components/parameters/OriginHeaderOptional" },
          { "$ref": "#/components/parameters/XClientOriginHeader" }
        ],
        "responses": {
          "200": {
            "description": "Resultado del diálogo o origen ya autorizado",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/OriginPromptResponse" },
                "examples": {
                  "confiado": { "value": { "trusted": true, "prompted": true } },
                  "yaAutorizado": { "value": { "trusted": true, "prompted": false } },
                  "rechazado": { "value": { "trusted": false, "prompted": true } }
                }
              }
            }
          },
          "400": {
            "description": "Falta cabecera Origin o URL inválida",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiError" },
                "example": {
                  "error": "missing_origin",
                  "detail": "Se requiere Origin o X-Client-Origin (loopback) con la URL del cliente"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/focus": {
      "post": {
        "tags": ["utils"],
        "summary": "Enfocar NexoSign (y opcionalmente un intent)",
        "description": "Muestra la ventana principal. Con `intent` en el cuerpo, notifica a la UI el `request_id` del lote pendiente y abre el asistente de firma.",
        "operationId": "postFocus",
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/FocusBody" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Ventana enfocada",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/FocusResponse" }
              }
            }
          },
          "503": {
            "description": "App no disponible",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiError" }
              }
            }
          }
        }
      }
    },
    "/api/v1/batch/sign/intent": {
      "post": {
        "tags": ["batch"],
        "summary": "Registrar intención de firma (sin encolar)",
        "description": "Registra PDFs para el asistente en la app **sin encolar la firma**. Integración web: **`multipart/form-data`** con el campo repetible **`files`** (un PDF por parte). También **`application/json`** con rutas absolutas locales (`inputs`). La política de origen la aplica el servidor (CORS / sitios permitidos); desde otro dominio el navegador envía `Origin` sin configurarlo aquí.",
        "operationId": "postBatchSignIntent",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["inputs"],
                "properties": {
                  "inputs": {
                    "type": "array",
                    "items": { "type": "string" },
                    "description": "Rutas absolutas a PDF en disco"
                  }
                }
              }
            },
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["files"],
                "properties": {
                  "files": {
                    "type": "string",
                    "format": "binary",
                    "description": "PDF a registrar. Repite el mismo nombre de campo `files` por cada archivo (hasta el máximo del producto)."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Intención creada",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["request_id"],
                  "properties": {
                    "request_id": {
                      "type": "string",
                      "format": "uuid",
                      "description": "Identificador del intent; abrir la app con POST /api/v1/focus y `{ \"intent\": \"<request_id>\" }`"
                    }
                  }
                }
              }
            }
          },
          "400": { "description": "Cuerpo inválido, PDF no válido o tamaños fuera de límite (validación de negocio)" },
          "403": { "description": "Origen no autorizado (`origin_not_trusted`)" },
          "415": { "description": "Content-Type no soportado" }
        }
      }
    },
    "/api/v1/batch/sign/intent/{request_id}/status": {
      "get": {
        "tags": ["batch"],
        "summary": "Estado del intent (portal sin backend)",
        "description": "Sondeo desde el navegador con el **`request_id`** devuelto por `POST …/intent`. Fases: **`awaiting_confirmation`** (intención aún abierta), **`processing`** (ya hay `job_id`, el worker no ha registrado salidas), **`completed`** (firma terminada; usar `manifest_href` y `GET …/jobs/{job_id}/files/{i}`). Política de origen en servidor.",
        "operationId": "getBatchSignIntentStatus",
        "parameters": [
          {
            "name": "request_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Estado actual",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["request_id", "phase"],
                  "properties": {
                    "request_id": { "type": "string" },
                    "phase": {
                      "type": "string",
                      "enum": [
                        "awaiting_confirmation",
                        "processing",
                        "completed"
                      ]
                    },
                    "job_id": {
                      "type": "string",
                      "nullable": true,
                      "description": "Presente en processing y completed"
                    },
                    "signed_file_count": {
                      "type": "integer",
                      "description": "Solo en completed: número de PDF firmados correctamente"
                    },
                    "manifest_href": {
                      "type": "string",
                      "description": "Ruta relativa al listado de descargas (processing y completed)"
                    }
                  }
                }
              }
            }
          },
          "403": { "description": "Origen no autorizado" },
          "404": { "description": "request_id desconocido o sin correlación intent→job" }
        }
      }
    },
    "/api/v1/batch/jobs/{job_id}/signed-files": {
      "get": {
        "tags": ["batch"],
        "summary": "Listar PDF firmados listos para descargar",
        "description": "Tras terminar el trabajo `job_id`, devuelve índices y rutas relativas `href` para `GET …/files/{file_index}`. Política de origen en servidor.",
        "operationId": "getBatchSignedManifest",
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de ficheros firmados",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "job_id": { "type": "string" },
                    "count": { "type": "integer" },
                    "files": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "index": { "type": "integer" },
                          "filename": { "type": "string" },
                          "href": { "type": "string" }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "403": { "description": "Origen no autorizado" },
          "404": { "description": "Trabajo sin salidas registradas o aún en curso" }
        }
      }
    },
    "/api/v1/batch/jobs/{job_id}/files/{file_index}": {
      "get": {
        "tags": ["batch"],
        "summary": "Descargar un PDF firmado",
        "description": "Devuelve el PDF en **`application/pdf`** (cabecera `Content-Disposition: attachment`). El índice coincide con `signed-files`. Política de origen en servidor.",
        "operationId": "downloadBatchSignedFile",
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "file_index",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "minimum": 0 }
          }
        ],
        "responses": {
          "200": {
            "description": "Cuerpo binario PDF",
            "content": {
              "application/pdf": {
                "schema": { "type": "string", "format": "binary" }
              }
            }
          },
          "403": { "description": "Origen no autorizado" },
          "404": { "description": "Índice fuera de rango o fichero ya no en disco" },
          "413": { "description": "PDF demasiado grande para servir" }
        }
      }
    }
  }
}
