{
  "name": "nexosign",
  "version": "0.1.0",
  "description": "NexoSign — firma con DNIe y bridge web (Tauri)",
  "type": "module",
  "scripts": {
    "sync:web-icon": "node -e \"require('fs').copyFileSync('src-tauri/icons/128x128.png','static/favicon.png')\"",
    "predev": "npm run sync:web-icon",
    "prebuild": "npm run sync:web-icon",
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "svelte-kit sync && vitest run",
    "test:watch": "svelte-kit sync && vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "test:all": "npm run test && npm run test:e2e && npm run test:rust",
    "tauri": "tauri",
    "load-test:gen-pdfs": "node scripts/gen-load-test-pdfs.mjs"
  },
  "license": "MIT",
  "dependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@lucide/svelte": "^1.14.0",
    "@playwright/test": "^1.52.0",
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tauri-apps/cli": "^2",
    "@types/node": "^22.15.0",
    "bits-ui": "^2.18.1",
    "mode-watcher": "^1.1.0",
    "shadcn-svelte": "^1.2.7",
    "svelte": "^5.55.5",
    "svelte-check": "^4.0.0",
    "svelte-sonner": "^1.1.1",
    "tailwind-variants": "^3.2.2",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vitest": "^3.2.0"
  }
}
